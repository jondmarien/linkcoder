{
  "name": "chron0-link-shortener",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply chron0-link-shortener --local",
    "db:migrate:remote": "wrangler d1 migrations apply chron0-link-shortener --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "resend": "^6.12.2"
  }
}
